# pwnMyKali — zsh configuration

# Powerlevel10k instant prompt — keep at the top.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
  git
  sudo
  encode64
  command-not-found
  colored-man-pages
  extract
  zsh-autosuggestions
  zsh-syntax-highlighting
)

source "$ZSH/oh-my-zsh.sh"

# Editor preferences
export EDITOR='nvim'
export VISUAL='nvim'

# History
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE SHARE_HISTORY

# Modern alternatives — kept as new commands, not overrides of `ls` / `cat`,
# so muscle memory and scripts that depend on coreutils keep working.
alias ll='lsd -lh'
alias la='lsd -lha'
alias lt='lsd --tree'
alias bcat='batcat --paging=never'
alias vim='nvim'
alias vi='nvim'

# Quality of life
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias mkdir='mkdir -pv'
alias grep='grep --color=auto'
alias diff='diff --color=auto'
alias df='df -h'
alias free='free -h'
alias ports='ss -tulpn'
alias myip='curl -s ifconfig.me; echo'
alias lanip="ip -4 -br addr | awk '{print \$1, \$3}'"

# Pentesting shortcuts
alias serve='python3 -m http.server'              # serve $PWD on :8000
alias serve8080='python3 -m http.server 8080'
alias listen='nc -lvnp'                            # listen <port>
alias urldecode='python3 -c "import sys, urllib.parse as u; print(u.unquote(sys.argv[1]))"'
alias urlencode='python3 -c "import sys, urllib.parse as u; print(u.quote(sys.argv[1]))"'
alias b64d='base64 -d'
alias b64e='base64 -w0'

# Polybar target widget shortcuts
alias t='target'
alias tt='target reset'

# fzf keybindings if installed
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Powerlevel10k user config
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
